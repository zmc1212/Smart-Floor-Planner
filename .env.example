# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DOUBAO_API_KEY: Required for Doubao (Volcengine) API calls.
DOUBAO_API_KEY="MY_DOUBAO_API_KEY"
# DOUBAO_MODEL_ID: The Endpoint ID or model name for Doubao T2I (e.g., doubao-t2i-v3)
DOUBAO_MODEL_ID="doubao-t2i-v3"

# QWEN_API_KEY: Required for Qwen (Aliyun DashScope) API calls.
QWEN_API_KEY="MY_QWEN_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
