.properties-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  box-shadow: 0 -1rpx 0 0 var(--ds-gray-alpha-400), 0 -10px 40rpx rgba(0,0,0,0.05);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 40;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  box-sizing: border-box;
}

.properties-panel view,
.properties-panel scroll-view,
.properties-panel input,
.properties-panel text,
.properties-panel image {
  box-sizing: border-box;
}

.properties-panel.visible {
  transform: translateY(0);
}

.drag-handle {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 16rpx;
}

.drag-bar {
  width: 48rpx;
  height: 6rpx;
  background: var(--ds-gray-100);
  border-radius: 4rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 32rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -1.28rpx;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  color: var(--ds-gray-600);
  font-size: 28rpx;
  box-shadow: var(--shadow-border);
}

.header-btn:active {
  background: #fafafa;
}

.header-btn-danger {
  color: var(--ship-red);
}

.panel-content {
  flex: 1;
  width: 100%;
  padding: 0 40rpx 40rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-group-half {
  flex: 1;
}

.form-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 18rpx;
  font-weight: 600;
  color: var(--ds-gray-600);
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
  margin-bottom: 12rpx;
}

.form-label-sm {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #ffffff;
  box-shadow: var(--shadow-border);
  border-radius: 6rpx;
  font-size: 28rpx;
  color: #171717;
  box-sizing: border-box;
  transition: box-shadow 0.1s;
}

.form-input:focus {
  box-shadow: 0 0 0 2rpx #171717;
}

.form-input-sm {
  width: 100%;
  height: 60rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  padding: 0 16rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #111827;
  box-sizing: border-box;
}

.form-input[disabled] {
  background: #fafafa;
  color: var(--ds-gray-400);
}

/* 分隔线 */
.section-divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 24rpx 0;
}

/* 激光测距边选择 */
.edge-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.edge-btn {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--ds-gray-600);
  background: #ffffff;
  box-shadow: var(--shadow-border);
  border-radius: 6rpx;
  transition: all 0.1s;
  font-weight: 500;
}

.edge-btn.active {
  background: #fafafa;
  box-shadow: 0 0 0 2rpx #171717;
  color: #171717;
  font-weight: 600;
}

/* 合并区域 */
.merge-section {
  background: #eff6ff;
  padding: 32rpx;
  border-radius: 20rpx;
  border: 1rpx solid #dbeafe;
  box-sizing: border-box;
}

.merge-hint {
  font-size: 26rpx;
  color: #1e40af;
  margin-bottom: 24rpx;
  display: block;
}

/* 门窗列表 */
.openings-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 12rpx;
}

.opening-card {
  background: #ffffff;
  padding: 24rpx;
  border-radius: 8rpx;
  box-shadow: var(--shadow-border);
  margin-bottom: 16rpx;
}

.opening-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.opening-type {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--develop-blue);
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.opening-delete {
  font-size: 22rpx;
  color: #9ca3af;
  padding: 4rpx;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.color-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: transform 0.2s;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.color-dot:active {
  transform: scale(1.1);
}

.color-dot-active {
  border-color: #3b82f6;
}

/* 段落头部 */
.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

/* 装修风格选择 */
.style-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.style-btn {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  border-radius: 6rpx;
  background: #ffffff;
  box-shadow: var(--shadow-border);
  color: var(--ds-gray-600);
  transition: all 0.1s;
}

.style-btn:active {
  border-color: #c084fc;
}

.style-btn-active {
  background: #171717;
  color: #ffffff;
  box-shadow: none;
  font-weight: 600;
}

/* 渲染预览 */
.rendering-preview {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
  background: #fafafa;
}

.rendering-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.rendering-overlay {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
}

.rendering-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0,0,0,0.8);
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  text-transform: uppercase;
}

.rendering-placeholder {
  width: 100%;
  height: 250rpx;
  background: #f9fafb;
  border-radius: 20rpx;
  border: 4rpx dashed #e5e7eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.placeholder-icon {
  font-size: 48rpx;
  opacity: 0.2;
}

.placeholder-text {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 按钮组 */
.btn-primary {
  width: 100% !important;
  background: #171717 !important;
  color: #ffffff !important;
  padding: 28rpx !important;
  border-radius: 6rpx !important;
  font-weight: 600 !important;
  font-size: 26rpx !important;
  letter-spacing: 0.5rpx !important;
  line-height: 1 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.btn-blue {
  background: var(--develop-blue) !important;
  color: #ffffff !important;
  line-height: 1 !important;
}

.btn-gradient {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #9333ea, #2563eb);
  color: #ffffff;
  padding: 24rpx;
  border-radius: 20rpx;
  font-weight: 500;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(147,51,234,0.3);
  margin-top: 16rpx;
  box-sizing: border-box;
}

.btn-gradient:active {
  transform: scale(0.97);
}

.btn-outline {
  width: 100% !important;
  background: #ffffff !important;
  color: #171717 !important;
  box-shadow: var(--shadow-border) !important;
  padding: 28rpx !important;
  border-radius: 6rpx !important;
  font-weight: 600 !important;
  font-size: 26rpx !important;
  margin-top: 16rpx !important;
}

.btn-link {
  text-align: center;
  font-size: 24rpx;
  color: #3b82f6;
  padding: 12rpx;
  margin-bottom: 8rpx;
}

.loading-icon {
  font-size: 32rpx;
  display: inline-block;
}

/* AI 建议 */
.advice-card {
  background: rgba(239,246,255,0.5);
  padding: 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(191,219,254,0.5);
}

.advice-text {
  font-size: 24rpx;
  color: #1e3a5f;
  line-height: 1.8;
}

.advice-placeholder {
  background: #f9fafb;
  padding: 32rpx;
  border-radius: 20rpx;
  border: 4rpx dashed #e5e7eb;
  text-align: center;
}

/* 提示 */
.tips-section {
  background: #eff6ff;
  padding: 24rpx;
  border-radius: 20rpx;
  margin-top: 32rpx;
}

.tips-title {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #1d4ed8;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.tips-item {
  display: block;
  font-size: 22rpx;
  color: #2563eb;
  opacity: 0.8;
  line-height: 2;
}
