.poster-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.poster-container {
  width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.poster-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f1f5f9;
}

.poster-header text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
}

.close-btn {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 10rpx;
}

.poster-body {
  padding: 40rpx;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-preview {
  width: 480rpx;
  height: 704rpx; /* 逻辑尺寸的 0.64 倍，保持比例 */
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.1);
}

.poster-placeholder {
  width: 480rpx;
  height: 704rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.poster-placeholder text {
  font-size: 24rpx;
  color: #94a3b8;
}

.poster-footer {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.save-btn {
  width: 100% !important;
  background: #1e293b;
  color: #fff;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.save-btn:active {
  background: #0f172a;
  transform: scale(0.98);
}

.tip {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
}
