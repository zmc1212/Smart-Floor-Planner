.ble-entry-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  padding: 40rpx;
}

.ble-entry-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.ble-entry-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.ble-entry-subtitle {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 60rpx;
  text-align: center;
}

.ble-action-group {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  width: 100%;
  max-width: 500rpx;
}

.ble-btn-primary {
  background: #2563eb;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 100rpx;
  text-align: center;
  box-shadow: 0 8rpx 16rpx rgba(37, 99, 235, 0.2);
}

.ble-btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.ble-btn-outline {
  border: 2rpx solid #e5e7eb;
  background: #ffffff;
  color: #4b5563;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 100rpx;
  text-align: center;
}

.ble-btn-outline:active {
  background: #f3f4f6;
}
