.ble-entry-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  padding: 80rpx; /* Increased padding */
}

.ble-entry-icon {
  font-size: 100rpx;
  margin-bottom: 48rpx;
  filter: grayscale(1);
}

.ble-entry-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 16rpx;
  letter-spacing: -2.4rpx; /* Geist Display Tracking */
}

.ble-entry-subtitle {
  font-size: 24rpx;
  color: var(--ds-gray-600);
  margin-bottom: 80rpx;
  text-align: center;
  line-height: 1.6;
}

.ble-action-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  max-width: 480rpx;
}

.ble-btn-primary {
  background: #171717;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 32rpx;
  border-radius: 6rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
  transition: all 0.1s;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ble-btn-primary:active {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.ble-btn-outline {
  background: #ffffff;
  color: #171717;
  font-size: 28rpx;
  font-weight: 600;
  padding: 32rpx;
  border-radius: 6rpx;
  text-align: center;
  box-shadow: var(--shadow-border);
  transition: all 0.1s;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ble-btn-outline:active {
  background: #fafafa;
}
