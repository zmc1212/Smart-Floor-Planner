.guided-wizard-bar {
  width: 100%;
  background: #3b82f6;
  color: white;
  padding: 32rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  z-index: 100;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.wizard-text {
  flex: 1;
  text-align: center;
}

.wizard-btn-action {
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin: 0 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.wizard-btn-action:active {
  background: rgba(255, 255, 255, 0.3);
}

.wizard-cancel {
  padding: 0 24rpx;
  font-size: 24rpx;
  text-decoration: underline;
}
