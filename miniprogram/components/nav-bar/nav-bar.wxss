.nav-bar {
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  z-index: 20;
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.logo-box {
  width: 52rpx;
  height: 52rpx;
  background: #2563eb;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 28rpx;
  color: #ffffff;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.1;
}

.app-subtitle {
  font-size: 14rpx;
  color: #9ca3af;
  letter-spacing: 2rpx;
  font-weight: 500;
  margin-top: -2rpx;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-group {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 4rpx;
  gap: 4rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #4b5563;
}

.action-btn:active {
  background: rgba(255,255,255,0.8);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.action-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.nav-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e5e7eb;
  margin: 0 8rpx;
}
