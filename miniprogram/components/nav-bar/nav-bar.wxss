.nav-bar {
  background: #ffffff;
  box-shadow: 0 1rpx 0 0 var(--ds-gray-alpha-400); /* Bottom shadow border */
  z-index: 20;
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx; /* Increased padding */
  box-sizing: border-box;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-box {
  width: 48rpx;
  height: 48rpx;
  background: #171717;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -1.2rpx; /* Geist-like tracking */
  line-height: 1;
}

.app-subtitle {
  font-size: 11rpx;
  color: var(--ds-gray-600);
  letter-spacing: 1rpx;
  font-weight: 500;
  margin-top: 4rpx;
  text-transform: uppercase;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  font-size: 28rpx;
  color: var(--ds-gray-900);
  background: #ffffff;
  box-shadow: var(--shadow-border);
  transition: all 0.1s;
}

.action-btn:active {
  background: #fafafa;
  transform: translateY(1rpx);
}

.action-btn.disabled {
  opacity: 0.2;
  pointer-events: none;
}

.nav-divider {
  width: 1rpx;
  height: 32rpx;
  background: var(--ds-gray-100);
  margin: 0 8rpx;
}

.btn-export {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 6rpx;
  background: #171717;
  color: #ffffff;
}
