.library-container {
  flex: 1;
  padding: 80rpx 40rpx; /* Gallery-like massive padding */
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

.library-header {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 48rpx;
  color: #171717;
  letter-spacing: -1.28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reset-btn {
  font-size: 20rpx;
  color: #171717;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: #ffffff;
  box-shadow: var(--shadow-border);
  border-radius: 6rpx;
  transition: all 0.1s;
}

.reset-btn:active {
  background: #fafafa;
  transform: translateY(1rpx);
}

.layout-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 64rpx;
}

.layout-btn {
  padding: 12rpx 28rpx;
  background: #ffffff;
  box-shadow: var(--shadow-border);
  border-radius: 6rpx;
  font-size: 24rpx;
  color: var(--ds-gray-600);
  transition: all 0.1s;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.layout-btn:active {
  background: #fafafa;
}

.room-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.room-item {
  width: calc(50% - 12rpx);
  background: #ffffff;
  border-radius: 8rpx;
  padding: 40rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  transition: all 0.2s;
}

.room-item:active {
  transform: translateY(-2rpx);
  box-shadow: 
    0px 0px 0px 1px rgba(0,0,0,0.08), 
    0px 10px 40rpx rgba(0,0,0,0.08); /* Subtle intensification on hover */
}

.room-item-measured {
  box-shadow: 0 0 0 2rpx #171717; /* Vercel active style */
}

.room-icon {
  font-size: 56rpx;
  margin-bottom: 24rpx;
}

.room-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -0.6rpx;
  margin-bottom: 12rpx;
}

.room-status {
  display: inline-flex;
  font-size: 18rpx;
  color: var(--ds-gray-400);
  padding: 4rpx 12rpx;
  background: #fafafa;
  border-radius: 9999rpx;
  font-weight: 500;
  text-transform: uppercase;
}

.room-status.measured {
  background: #ebf5ff;
  color: #0068d6;
}

.room-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ai-btn {
  background: #171717;
  color: #fff;
  font-size: 18rpx;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-weight: 600;
  transition: all 0.1s;
  letter-spacing: 0.2rpx;
}

.ai-btn:active {
  opacity: 0.9;
}
