.toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 16rpx 24rpx;
  gap: 24rpx;
  z-index: 30;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.tool-wrapper {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.tool-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  transition: all 0.2s;
  position: relative;
  background: transparent;
}

.tool-btn-active {
  background: #2563eb;
  box-shadow: 0 8rpx 20rpx rgba(37,99,235,0.3);
}

.tool-btn-active .tool-icon {
  color: #ffffff;
}

.tool-icon {
  font-size: 40rpx;
  color: #6b7280;
  line-height: 1;
}

.tool-label {
  font-size: 18rpx;
  color: #9ca3af;
  white-space: nowrap;
}

.tool-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 12rpx;
  height: 12rpx;
  background: #60a5fa;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

/* 房间类型菜单 */
.room-type-menu {
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  margin-bottom: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 60rpx rgba(0,0,0,0.15);
  border: 1rpx solid #f3f4f6;
  padding: 24rpx;
  min-width: 240rpx;
  z-index: 50;
}

.menu-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.menu-header-bar {
  width: 6rpx;
  height: 28rpx;
  background: #2563eb;
  border-radius: 6rpx;
}

.menu-header-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #111827;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #4b5563;
  transition: all 0.15s;
}

.menu-item:active {
  background: #f3f4f6;
}

.menu-item-active {
  background: #eff6ff;
  color: #1d4ed8;
  font-weight: 700;
}

.menu-item-check {
  font-size: 28rpx;
  font-weight: 700;
}

.menu-arrow {
  position: absolute;
  bottom: -12rpx;
  left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 24rpx;
  height: 24rpx;
  background: #ffffff;
  border-right: 1rpx solid #f3f4f6;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 29;
  background: transparent;
}
