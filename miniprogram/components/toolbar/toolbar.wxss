.toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  box-shadow: 0 1rpx 0 0 var(--ds-gray-alpha-400);
  padding: 16rpx 40rpx;
  gap: 32rpx;
  z-index: 30;
  position: relative;
}

.tool-wrapper {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.tool-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  transition: all 0.2s;
  position: relative;
  background: #ffffff;
  box-shadow: var(--shadow-border);
}

.tool-btn-active {
  background: #171717;
  box-shadow: none;
}

.tool-btn-active .tool-icon {
  color: #ffffff;
}

.tool-icon {
  font-size: 32rpx;
  color: var(--ds-gray-900);
  line-height: 1;
}

.tool-label {
  font-size: 18rpx;
  color: var(--ds-gray-600);
  white-space: nowrap;
  font-weight: 500;
  letter-spacing: -0.2rpx;
}

.tool-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 10rpx;
  height: 10rpx;
  background: var(--develop-blue);
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

/* 房间类型菜单 - Vercel Multi-layer Shadow Stack */
.room-type-menu {
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow: 
    0px 0px 0px 1px rgba(0,0,0,0.08), 
    0px 2px 2px rgba(0,0,0,0.04), 
    0px 8px 8px -8px rgba(0,0,0,0.04);
  padding: 16rpx;
  min-width: 280rpx;
  z-index: 50;
}

.menu-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 12rpx;
}

.menu-header-bar {
  width: 4rpx;
  height: 24rpx;
  background: #171717;
  border-radius: 4rpx;
}

.menu-header-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #171717;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: var(--ds-gray-600);
  transition: all 0.1s;
}

.menu-item:active {
  background: #fafafa;
}

.menu-item-active {
  background: #fafafa;
  color: #171717;
  font-weight: 600;
}

.menu-item-check {
  font-size: 24rpx;
  color: var(--develop-blue);
}

.menu-arrow {
  display: none; /* Vercel style usually avoids decorative arrows */
}

.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 29;
  background: transparent;
}
