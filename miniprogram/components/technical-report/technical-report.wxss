.report-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  backdrop-filter: blur(10px);
}

.report-container {
  width: 90%;
  height: 90vh;
  background: #ffffff;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.report-header {
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #f5f5f5;
}

.report-header .close-hit {
  padding: 10rpx 20rpx 10rpx 0;
}

.report-header .close {
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.report-header .title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
}

.header-placeholder {
  width: 80rpx;
}

.report-content {
  flex: 1;
  background: #f1f1f1;
}

.result-image {
  width: 100%;
  display: block;
}

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 24rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #eee;
  border-top-color: #0070f3;
  border-radius: 50%;
  margin-bottom: 20rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.report-footer {
  padding: 40rpx;
  background: #fff;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.05);
}

.btn-save {
  width: 100%;
  height: 100rpx;
  background: #171717;
  color: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.btn-save[disabled] {
  background: #eee;
  color: #ccc;
}
