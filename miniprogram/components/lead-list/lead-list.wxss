:host {
  display: block;
  flex: 1;
  min-height: 0;
}

.lead-list-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #fcfcfc;
}

/* 搜索栏 */
.search-header {
  padding: 24rpx 32rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f4f4f5;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  gap: 16rpx;
}

.add-lead-btn {
  width: 72rpx;
  height: 72rpx;
  background: #171717;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-icon {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #171717;
}

/* 选项卡 */
.tabs-nav {
  background: #ffffff;
  border-bottom: 1rpx solid #efeff1;
}

.tabs-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.tab-item.active .tab-label {
  color: #171717;
  font-weight: 600;
}

.tab-underline {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background: #171717;
  border-radius: 2rpx;
}

/* 加载状态 */
.loading-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 24rpx;
  gap: 20rpx;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #171717;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 内容区域 */
.swiper-content {
  flex: 1;
  height: calc(100vh - 300rpx); /* 粗略计算，会被 flex:1 覆盖 */
}

.list-scroll {
  height: 100%;
}

.leads-grid {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 卡片设计 - Vercel Layered Style */
.lead-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06), 0px 2px 4px rgba(0,0,0,0.02);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  transition: all 0.2s;
}

.lead-card:active {
  transform: scale(0.98);
  background: #fafafa;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.status-badge.new { background: #e0f2fe; color: #0284c7; }
.status-badge.measuring { background: #fef3c7; color: #d97706; }
.status-badge.designing { background: #f3e8ff; color: #9333ea; }
.status-badge.converted { background: #dcfce7; color: #16a34a; }

.date-text {
  font-size: 22rpx;
  color: #999;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.customer-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.customer-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
}

.customer-community {
  font-size: 24rpx;
  color: #666;
}

.customer-phone {
  font-size: 24rpx;
  color: #0070f3;
  font-weight: 500;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx dashed #efeff1;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #666;
}

.action-btn {
  background: #171717;
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.2;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #888;
}

.load-more-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 32rpx;
}
