.status-bar {
  height: 88rpx;
  background: #ffffff;
  box-shadow: 0 -1rpx 0 0 var(--ds-gray-alpha-400);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.status-text {
  font-size: 20rpx;
  color: var(--ds-gray-600);
  font-family: 'ui-monospace', 'SFMono-Regular', Menlo, monospace;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.ble-btn {
  font-size: 18rpx;
  background: var(--ship-red);
  color: #ffffff;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-weight: 600;
  text-transform: uppercase;
}

.ble-btn:active {
  opacity: 0.8;
}

.status-ready {
  font-size: 20rpx;
  color: var(--develop-blue);
  font-weight: 600;
  font-family: 'ui-monospace', 'SFMono-Regular', Menlo, monospace;
  text-transform: uppercase;
}
