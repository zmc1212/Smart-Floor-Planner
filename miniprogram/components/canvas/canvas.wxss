.canvas-container {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
  position: relative;
  overflow: hidden;
}

.floor-canvas {
  width: 100%;
  height: 100%;
}

/* 浮动快捷菜单 */
.float-menu {
  position: absolute;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(10px);
  padding: 6rpx 8rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
  border: 1rpx solid #e5e7eb;
  transform: translate(-50%, -100%);
}

.float-menu-label {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #6b7280;
  border-right: 1rpx solid #f3f4f6;
  margin-right: 4rpx;
}

.float-menu-btn {
  padding: 8rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.float-menu-btn:active {
  background: #f3f4f6;
}

.float-menu-icon {
  font-size: 24rpx;
}
