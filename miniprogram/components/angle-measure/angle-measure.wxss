/* Vercel Design System — Angle Measure Modal */

/* ===== 容器 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.angle-modal-container {
  position: relative;
  width: 100%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow:
    0px 0px 0px 1px rgba(0,0,0,0.08),
    0px 24px 64rpx -12px rgba(0,0,0,0.12),
    rgba(255,255,255,1) 0px 0px 0px 1px inset;
  padding: 64rpx 48rpx;
  box-sizing: border-box;
  max-height: 92vh;
  display: flex;
  flex-direction: column;
}

.modal-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #888;
  font-size: 32rpx;
  z-index: 10;
}

/* ===== 标题区 ===== */
.title-section {
  text-align: center;
  margin-bottom: 56rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -1.2rpx;
  margin-bottom: 12rpx;
}

.modal-subtitle {
  display: block;
  font-size: 18rpx;
  color: #999;
  letter-spacing: 0.4rpx;
  text-transform: uppercase;
  font-weight: 500;
}

/* ===== 步骤指示器 ===== */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 48rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 1rpx rgba(0,0,0,0.06);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  flex-shrink: 0;
}

.step-dot.done {
  background: #171717;
  box-shadow: none;
}

.step-dot.current {
  background: #171717;
  box-shadow: 0 0 0 4rpx rgba(23,23,23,0.15);
  transform: scale(1.1);
}

.step-num {
  font-size: 20rpx;
  font-weight: 600;
  color: #999;
}

.step-dot.done .step-num,
.step-dot.current .step-num {
  color: #ffffff;
}

.step-line {
  width: 56rpx;
  height: 2rpx;
  background: #e5e5e5;
  transition: background 0.3s;
}

.step-line.done {
  background: #171717;
}

/* ===== 步骤说明 ===== */
.step-info {
  text-align: center;
  margin-bottom: 48rpx;
}

.step-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -0.8rpx;
  margin-bottom: 8rpx;
}

.step-desc {
  display: block;
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
}

/* ===== 三角形示意图 ===== */
.triangle-preview {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}

.triangle-svg-wrapper {
  width: 320rpx;
  height: 240rpx;
  position: relative;
}

.tri-shape {
  position: relative;
  width: 100%;
  height: 100%;
}

/* 边 - 基础样式 */
.tri-edge {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 墙A - 左侧竖边 */
.edge-a {
  left: 40rpx;
  top: 20rpx;
  width: 4rpx;
  height: 180rpx;
  background: #e0e0e0;
  flex-direction: column;
}
.edge-a .edge-label {
  position: absolute;
  left: -80rpx;
  white-space: nowrap;
  font-size: 20rpx;
  color: #999;
}
.edge-a.measured {
  background: #171717;
}
.edge-a.measured .edge-label {
  color: #171717;
  font-weight: 600;
}
.edge-a.measuring {
  background: var(--ship-red, #ff5b4f);
  animation: pulse-edge 1.2s ease-in-out infinite;
}

/* 墙B - 底边 */
.edge-b {
  left: 40rpx;
  bottom: 20rpx;
  width: 240rpx;
  height: 4rpx;
  background: #e0e0e0;
}
.edge-b .edge-label {
  position: absolute;
  bottom: -36rpx;
  white-space: nowrap;
  font-size: 20rpx;
  color: #999;
}
.edge-b.measured {
  background: #171717;
}
.edge-b.measured .edge-label {
  color: #171717;
  font-weight: 600;
}
.edge-b.measuring {
  background: var(--ship-red, #ff5b4f);
  animation: pulse-edge 1.2s ease-in-out infinite;
}

/* 对角线 */
.edge-d {
  left: 40rpx;
  top: 20rpx;
  width: 308rpx;
  height: 4rpx;
  background: #e0e0e0;
  transform-origin: 0 50%;
  transform: rotate(35.5deg);
}
.edge-d .edge-label {
  position: absolute;
  top: -32rpx;
  right: 20rpx;
  white-space: nowrap;
  font-size: 20rpx;
  color: #999;
}
.edge-d.measured {
  background: var(--develop-blue, #0070f3);
}
.edge-d.measured .edge-label {
  color: var(--develop-blue, #0070f3);
  font-weight: 600;
}
.edge-d.measuring {
  background: var(--ship-red, #ff5b4f);
  animation: pulse-edge 1.2s ease-in-out infinite;
}

/* 角度弧 */
.tri-angle-arc {
  position: absolute;
  left: 50rpx;
  bottom: 30rpx;
  width: 56rpx;
  height: 56rpx;
  border: 3rpx solid var(--develop-blue, #0070f3);
  border-radius: 50%;
  clip-path: polygon(0 0, 100% 0, 100% 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.angle-value {
  position: absolute;
  left: 60rpx;
  bottom: -8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--develop-blue, #0070f3);
  white-space: nowrap;
  font-family: var(--font-mono, 'Geist Mono', monospace);
}

/* 顶点 */
.tri-vertex {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #171717;
  z-index: 2;
}
.vertex-origin {
  left: 36rpx;
  bottom: 16rpx;
}
.vertex-a {
  left: 36rpx;
  top: 16rpx;
}
.vertex-b {
  right: 36rpx;
  bottom: 16rpx;
}

/* ===== 结果卡片 ===== */
.result-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.result-card {
  flex: 1;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  box-shadow: inset 0 0 0 1rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  position: relative;
}

.result-card.active {
  box-shadow: 0 0 0 2rpx #171717;
}

.rc-label {
  font-size: 18rpx;
  color: #888;
  font-weight: 500;
}

.rc-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #171717;
  font-family: var(--font-mono, 'Geist Mono', monospace);
}

.rc-action {
  font-size: 16rpx;
  color: var(--develop-blue, #0070f3);
  margin-top: 2rpx;
}

/* ===== 角度结果 ===== */
.angle-result {
  margin-bottom: 48rpx;
}

.angle-result-inner {
  background: #f0fdf4;
  border-radius: 8rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: inset 0 0 0 1rpx rgba(16,185,129,0.2);
}

.angle-result-inner.invalid {
  background: #fef2f2;
  box-shadow: inset 0 0 0 1rpx rgba(239,68,68,0.2);
}

.angle-result-label {
  display: block;
  font-size: 20rpx;
  color: #888;
  margin-bottom: 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  font-weight: 600;
}

.angle-result-value {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #171717;
  font-family: var(--font-mono, 'Geist Mono', monospace);
  letter-spacing: -2rpx;
}

.angle-result-hint {
  display: block;
  font-size: 22rpx;
  color: #ef4444;
  margin-top: 8rpx;
}

/* ===== 提示区 ===== */
.hint-section {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #fafafa;
  padding: 32rpx;
  border-radius: 8rpx;
  margin-bottom: 56rpx;
  box-shadow: inset 0 0 0 1rpx rgba(0,0,0,0.04);
}

.hint-icon {
  font-size: 24rpx;
  color: var(--develop-blue, #0070f3);
  margin-top: 4rpx;
}

.hint-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
}

/* ===== 操作按钮 ===== */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  width: 100% !important;
  background: #171717 !important;
  color: #ffffff !important;
  font-weight: 600 !important;
  padding: 32rpx 0 !important;
  border-radius: 8rpx !important;
  font-size: 28rpx !important;
  margin: 0 !important;
  box-shadow: none !important;
}

.btn-outline {
  width: 100% !important;
  background: #ffffff !important;
  color: #171717 !important;
  font-weight: 500 !important;
  padding: 28rpx 0 !important;
  border-radius: 8rpx !important;
  font-size: 24rpx !important;
  margin: 0 !important;
  box-shadow: 0 0 0 1rpx rgba(0,0,0,0.08) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.btn-retry {
  margin-top: 8rpx !important;
}

.btn-confirm.loading {
  opacity: 0.6;
  pointer-events: none;
}

/* ===== 动画 ===== */
@keyframes pulse-edge {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.blink {
  animation: blink-text 1.5s ease-in-out infinite;
}

@keyframes blink-text {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
