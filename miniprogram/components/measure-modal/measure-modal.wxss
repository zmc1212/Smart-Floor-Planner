.measure-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.measure-modal {
  width: 640rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.2);
  display: flex;
  flex-direction: column;
}

.measure-modal-header {
  background: #2563eb;
  color: #fff;
  padding: 24rpx 30rpx;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.step-badge {
  font-size: 24rpx;
  background: rgba(255,255,255,0.25);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.measure-modal-content {
  padding: 30rpx 36rpx;
  font-size: 28rpx;
  color: #374151;
}

.dir-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

/* 方向按钮网格 */
.direction-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.dir-btn {
  background: #f1f5f9;
  border: 3rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 18rpx 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.dir-btn.active {
  background: #eff6ff;
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37,99,235,0.15);
}

.dir-arrow {
  font-size: 30rpx;
  font-weight: 700;
  color: #334155;
}

.dir-btn.active .dir-arrow {
  color: #2563eb;
}

.dir-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.dir-btn.active .dir-desc {
  color: #3b82f6;
}

/* 方向预览图 */
.dir-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.dir-room-box {
  position: relative;
  width: 160rpx;
  height: 120rpx;
  border: 4rpx solid #cbd5e1;
  background: #fff;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}

.dir-origin {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  background: #334155;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.dir-indicator {
  position: absolute;
  background: #e2e8f0;
  transition: all 0.2s;
}
.dir-indicator.active { background: #ef4444; box-shadow: 0 0 8rpx rgba(239,68,68,0.5); }

/* 四个方向条 */
.dir-indicator.E { top: 50%; right: 0; width: 50%; height: 4rpx; transform: translateY(-50%); transform-origin: left center; }
.dir-indicator.S { left: 50%; bottom: 0; height: 50%; width: 4rpx; transform: translateX(-50%); transform-origin: center top; }
.dir-indicator.W { top: 50%; left: 0; width: 50%; height: 4rpx; transform: translateY(-50%); transform-origin: right center; }
.dir-indicator.N { left: 50%; top: 0; height: 50%; width: 4rpx; transform: translateX(-50%); transform-origin: center bottom; }

.dir-hint {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 底部确认按钮 */
.measure-modal-footer {
  padding: 0 36rpx 36rpx;
}

.measure-btn-confirm {
  background: #2563eb;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.2);
}
