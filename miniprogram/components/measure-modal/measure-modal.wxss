.measure-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.measure-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.2);
  display: flex;
  flex-direction: column;
}

.measure-modal-header {
  background: #2563eb;
  color: #fff;
  padding: 30rpx;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
}

.measure-modal-content {
  padding: 40rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #374151;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 图形引导区域 */
.visual-guide {
  width: 400rpx;
  height: 320rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 20rpx;
  border: 2rpx solid #e2e8f0;
}

.room-box {
  position: relative;
  width: 240rpx;
  height: 180rpx;
  border: 4rpx solid #cbd5e1;
  background: #fff;
}

.wall {
  position: absolute;
  background: transparent;
  transition: all 0.3s ease;
}

.wall.top { top: -4rpx; left: 0; width: 100%; height: 8rpx; }
.wall.bottom { bottom: -4rpx; left: 0; width: 100%; height: 8rpx; }
.wall.left { top: 0; left: -4rpx; width: 8rpx; height: 100%; }
.wall.right { top: 0; right: -4rpx; width: 8rpx; height: 100%; }

.wall.active {
  background: #2563eb;
  box-shadow: 0 0 15rpx rgba(37, 99, 235, 0.6);
  z-index: 10;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.6; }
  100% { opacity: 1; }
}

/* 激光指示线 */
.laser-line {
  position: absolute;
  background: rgba(239, 68, 68, 0.4);
  z-index: 5;
}

.laser-line.top { bottom: 0; left: 50%; width: 2rpx; height: 140rpx; transform: translateX(-50%); border-left: 2rpx dashed #ef4444; }
.laser-line.bottom { top: 0; left: 50%; width: 2rpx; height: 140rpx; transform: translateX(-50%); border-left: 2rpx dashed #ef4444; }
.laser-line.left { top: 50%; right: 0; height: 2rpx; width: 200rpx; transform: translateY(-50%); border-top: 2rpx dashed #ef4444; }
.laser-line.right { top: 50%; left: 0; height: 2rpx; width: 200rpx; transform: translateY(-50%); border-top: 2rpx dashed #ef4444; }

.laser-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: #ef4444;
  border-radius: 50%;
  box-shadow: 0 0 8rpx #ef4444;
}

.laser-line.top .laser-dot { top: 10rpx; left: -4rpx; }
.laser-line.bottom .laser-dot { bottom: 10rpx; left: -4rpx; }
.laser-line.left .laser-dot { left: 10rpx; top: -4rpx; }
.laser-line.right .laser-dot { right: 10rpx; top: -4rpx; }

/* 测距仪图标 */
.device-icon {
  position: absolute;
  width: 40rpx;
  height: 60rpx;
  background: #334155;
  border-radius: 4rpx;
  z-index: 20;
}

.device-icon.top { bottom: -10rpx; left: 50%; transform: translateX(-50%); }
.device-icon.bottom { top: -10rpx; left: 50%; transform: translateX(-50%); }
.device-icon.left { right: -10rpx; top: 50%; transform: translateY(-50%) rotate(90deg); }
.device-icon.right { left: -10rpx; top: 50%; transform: translateY(-50%) rotate(90deg); }

.device-body {
  width: 100%;
  height: 100%;
  position: relative;
}

.device-body::after {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  height: 15rpx;
  background: #94a3b8;
  border-radius: 2rpx;
}

.measure-modal-footer {
  padding: 0 40rpx 40rpx;
}

.measure-btn-confirm {
  background: #2563eb;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.2);
}
