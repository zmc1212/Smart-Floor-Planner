/* Vercel Design System - Measure Modal */

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.modal-container {
  width: 90%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 
    0px 0px 0px 1px rgba(0,0,0,0.08), 
    0px 10px 40rpx rgba(0,0,0,0.08), 
    rgba(255,255,255,1) 0px 0px 0px 1px inset;
  padding: 56rpx;
  box-sizing: border-box;
}

.title-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -1.28rpx;
  display: block;
}

.modal-subtitle {
  font-size: 18rpx;
  color: var(--ds-gray-400);
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
  margin-top: 12rpx;
  display: block;
  font-weight: 600;
}

.direction-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.direction-cell {
  background: #ffffff;
  box-shadow: var(--shadow-border);
  border-radius: 6rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.1s;
}

.direction-cell.active {
  box-shadow: 0 0 0 2rpx #171717;
  background: #fafafa;
}

.dir-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -0.2rpx;
}

.dir-desc {
  font-size: 18rpx;
  color: var(--ds-gray-600);
  font-weight: 500;
}

.hint-section {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #fafafa;
  padding: 24rpx;
  border-radius: 6rpx;
  margin-bottom: 48rpx;
  box-shadow: inset 0 0 0 1rpx rgba(0,0,0,0.04);
}

.hint-icon {
  font-size: 24rpx;
  color: var(--develop-blue);
  margin-top: 4rpx;
}

.hint-text {
  font-size: 20rpx;
  color: var(--ds-gray-600);
  line-height: 1.6;
}

/* 方向预览图 - Vercel Engineering Aesthetic */
.dir-preview-box {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}

.dir-room-simulator {
  position: relative;
  width: 200rpx;
  height: 140rpx;
  box-shadow: var(--shadow-border);
  background: #ffffff;
  border-radius: 4rpx;
}

.simulator-origin {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: #171717;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
}

.laser-line {
  position: absolute;
  background: var(--ship-red);
  opacity: 0;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  z-index: 1;
}

.laser-line.active {
  opacity: 1;
  box-shadow: 0 0 8rpx rgba(255, 91, 79, 0.4);
}

.laser-line.E { top: 50%; left: 50%; width: 50%; height: 2rpx; transform: translateY(-50%); }
.laser-line.S { left: 50%; top: 50%; width: 2rpx; height: 50%; transform: translateX(-50%); }
.laser-line.W { top: 50%; right: 50%; width: 50%; height: 2rpx; transform: translateY(-50%); }
.laser-line.N { left: 50%; bottom: 50%; width: 2rpx; height: 50%; transform: translateX(-50%); }

.action-section {
  display: flex;
  flex-direction: column;
}

.btn-confirm {
  width: 100% !important;
  background: #171717 !important;
  color: #ffffff !important;
  font-weight: 600 !important;
  padding: 32rpx 0 !important;
  border-radius: 6rpx !important;
  letter-spacing: 0.5rpx !important;
  margin: 0 !important;
  font-size: 26rpx !important;
  line-height: 1 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.btn-confirm:active {
  opacity: 0.9;
}
