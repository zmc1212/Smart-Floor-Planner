<view class="measure-modal-mask" wx:if="{{show}}">
  <view class="measure-modal">
    <view class="measure-modal-header">
      <text>准备测量</text>
      <text class="step-badge">第 {{currentStep}} 边</text>
    </view>

    <view class="measure-modal-content">
      <!-- 方向选择器 -->
      <view class="dir-section-title">1. 选择本次测量方向</view>
      <view class="direction-grid">
        <view
          class="dir-btn {{selectedDirection === item.key ? 'active' : ''}}"
          wx:for="{{directions}}"
          wx:key="key"
          data-dir="{{item.key}}"
          bindtap="onSelectDirection"
        >
          <text class="dir-arrow">{{item.label}}</text>
          <text class="dir-desc">{{item.desc}}</text>
        </view>
      </view>

      <!-- 方向示意图 -->
      <view class="dir-preview">
        <view class="dir-room-box">
          <view class="dir-indicator E {{selectedDirection === 'E' ? 'active' : ''}}"></view>
          <view class="dir-indicator S {{selectedDirection === 'S' ? 'active' : ''}}"></view>
          <view class="dir-indicator W {{selectedDirection === 'W' ? 'active' : ''}}"></view>
          <view class="dir-indicator N {{selectedDirection === 'N' ? 'active' : ''}}"></view>
          <view class="dir-origin"></view>
        </view>
        <text class="dir-hint">激光从起点向所选方向射出</text>
      </view>

      <view class="dir-section-title" style="margin-top: 20rpx;">2. 放置测距仪后点击测量</view>
      <text style="font-size: 26rpx; color: #64748b;">将测距仪贴紧对应墙面，确保激光已开启</text>
    </view>

    <view class="measure-modal-footer">
      <view class="measure-btn-confirm" bindtap="onConfirm">已放好，立刻测量</view>
    </view>
  </view>
</view>
