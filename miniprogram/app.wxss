/* 
 * Vercel (Geist) Design System - Global Styles
 */

page {
  /* System Fonts prioritizing Geist-like geometric sans */
  font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background-color: #ffffff;
  color: #171717;
  height: 100%;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
  --ds-gray-100: #ebebeb;
  --ds-gray-400: #808080;
  --ds-gray-600: #4d4d4d;
  --ds-gray-900: #171717;
  --ds-gray-alpha-400: rgba(0, 0, 0, 0.08);
  --ds-gray-alpha-100: rgba(0, 0, 0, 0.04);
  
  /* Workflow Accents */
  --develop-blue: #0a72ef;
  --preview-pink: #de1d8d;
  --ship-red: #ff5b4f;
  
  /* Shadow Stacks */
  --shadow-border: 0 0 0 1rpx var(--ds-gray-alpha-400);
  --shadow-lift: 0 0 0 1rpx var(--ds-gray-alpha-400), 0 2rpx 2rpx var(--ds-gray-alpha-100);
  --shadow-card: 0 0 0 1rpx var(--ds-gray-alpha-400), 0 2rpx 2rpx var(--ds-gray-alpha-100), 0 8rpx 8rpx -8rpx var(--ds-gray-alpha-100);
}

/* 布局工具 */
.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-4 { gap: 8rpx; }
.gap-8 { gap: 16rpx; }

/* 影子描边 (Vercel Signature) */
.shadow-border { box-shadow: var(--shadow-border); }
.shadow-lift { box-shadow: var(--shadow-lift); }
.shadow-card { box-shadow: var(--shadow-card); }

/* 文字与排版 */
.text-xs { font-size: 20rpx; letter-spacing: 0; }
.text-sm { font-size: 24rpx; letter-spacing: -0.2rpx; }
.text-base { font-size: 28rpx; letter-spacing: -0.6rpx; }
.text-lg { font-size: 32rpx; letter-spacing: -1.28rpx; }
.text-xl { font-size: 36rpx; letter-spacing: -2.4rpx; font-weight: 600; line-height: 1.1; }

.font-bold { font-weight: 600; } /* Vercel uses 600 as max for headings */
.font-medium { font-weight: 500; }
.font-mono { font-family: 'ui-monospace', 'SFMono-Regular', 'Roboto Mono', Menlo, monospace; }

/* 颜色 */
.text-muted { color: var(--ds-gray-600); }
.text-disabled { color: var(--ds-gray-400); }
.text-main { color: var(--ds-gray-900); }
.text-blue { color: var(--develop-blue); }
.text-pink { color: var(--preview-pink); }
.text-red { color: var(--ship-red); }
.text-white { color: #ffffff; }

.bg-main { background-color: var(--ds-gray-900); }
.bg-white { background-color: #ffffff; }
.bg-sub { background-color: #fafafa; }
.bg-blue { background-color: var(--develop-blue); }

/* 圆角 */
.rounded-sm { border-radius: 4rpx; }
.rounded-md { border-radius: 6rpx; } /* Vercel standard */
.rounded-lg { border-radius: 8rpx; } /* Card standard */
.rounded-xl { border-radius: 12rpx; }
.rounded-full { border-radius: 9999rpx; }

/* 按钮基础 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  outline: none;
  background: #ffffff;
  padding: 12rpx 24rpx;
  margin: 0;
  line-height: 1; /* Critical for flex centering */
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 6rpx;
  box-shadow: var(--shadow-border);
  transition: all 0.15s ease;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #171717;
  color: #ffffff;
  box-shadow: none;
}

.btn-blue {
  background: var(--develop-blue);
  color: #ffffff;
  box-shadow: none;
}

.btn-ghost {
  box-shadow: none;
  background: transparent;
}

.btn:active {
  opacity: 0.8;
  transform: translateY(1rpx);
}

/* 滚动条 */
::-webkit-scrollbar {
  width: 2rpx;
}
::-webkit-scrollbar-thumb {
  background: var(--ds-gray-100);
  border-radius: 10rpx;
}
