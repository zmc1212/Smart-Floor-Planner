.container {
  padding: 40rpx;
  background-color: #f8f9fa;
  height: 100vh;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ===== Login Section ===== */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.login-icon {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
  background-color: #ebebeb;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.login-logo {
  width: 180rpx;
  height: 180rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 80rpx;
  text-align: center;
  padding: 0 60rpx;
}

.login-btn {
  width: 80% !important;
  background-color: #10b981;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border: none;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.85;
}

/* ===== Profile Header ===== */
.header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 160rpx !important;
  height: 160rpx !important;
  border-radius: 80rpx;
  background-color: #ebebeb;
  position: relative;
  overflow: visible;
  border: none;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  display: block;
}

.edit-badge {
  position: absolute;
  bottom: 0;
  right: -10rpx;
  background-color: #171717;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #fff;
}

/* ===== Identity Badge ===== */
.identity-badge {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #171717 0%, #333 100%);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.id-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.id-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 1rpx;
}

/* ===== Form ===== */
.form-group {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 30rpx;
  color: #333333;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #171717;
}

.phone-display {
  color: #10b981;
  font-weight: 500;
}

/* ===== Actions ===== */
.action-area {
  margin-top: 80rpx;
}

.save-btn {
  background-color: #171717;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 20rpx 0;
}

.save-btn:active {
  opacity: 0.8;
}

.logout-btn {
  margin-top: 24rpx;
  background-color: transparent;
  color: #999;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  color: #e53e3e;
}

/* ===== Floor Plans ===== */
/* ===== Floor Plans ===== */
.floorplan-section {
  margin-top: 60rpx;
  padding-bottom: 60rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
  letter-spacing: -0.02em;
}

.section-count {
  font-size: 24rpx;
  color: #9ea1a5;
}

.floorplan-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06), 0px 2px 4px rgba(0,0,0,0.02);
  transition: all 0.2s ease;
}

.floorplan-card:active {
  background-color: #fafafa;
  transform: scale(0.985);
}

.card-body {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.fp-icon-container {
  width: 96rpx;
  height: 96rpx;
  background: #f8f9fa;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.fp-emoji {
  font-size: 44rpx;
}

.fp-content {
  flex: 1;
  min-width: 0;
}

.fp-title-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.fp-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 70%;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.status-tag.completed {
  background: #ecfdf5;
  color: #10b981;
}

.status-tag.draft {
  background: #f4f4f5;
  color: #71717a;
}

.fp-info-line {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #888;
}

.fp-dot {
  margin: 0 12rpx;
  color: #ccc;
}

.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f1f1f1;
}

.ai-gen-btn {
  display: flex;
  align-items: center;
  background: #171717;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.ai-stars {
  margin-right: 12rpx;
  font-size: 26rpx;
}

.fp-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  width: 18rpx;
  height: 18rpx;
  border-top: 4rpx solid #d1d5db;
  border-right: 4rpx solid #d1d5db;
  transform: rotate(45deg);
}

/* ===== Empty State ===== */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 60rpx;
  animation: fadeIn 0.6s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.empty-visual {
  margin-bottom: 48rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  background: #f4f4f5;
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.empty-emoji {
  font-size: 72rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171717;
  margin-bottom: 16rpx;
  letter-spacing: -0.02em;
}

.empty-subtitle {
  font-size: 28rpx;
  color: #71717a;
  text-align: center;
  margin-bottom: 80rpx;
  line-height: 1.6;
}

.primary-btn {
  background: #171717;
  color: #fff;
  width: 380rpx !important;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.primary-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  opacity: 0.9;
}
