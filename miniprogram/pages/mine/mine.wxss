.container {
  padding: 40rpx;
  background-color: #f8f9fa;
  height: 100vh;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ===== Login Section ===== */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.login-icon {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
  background-color: #ebebeb;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.login-logo {
  width: 180rpx;
  height: 180rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 80rpx;
  text-align: center;
  padding: 0 60rpx;
}

.login-btn {
  width: 80% !important;
  background-color: #10b981;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border: none;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.85;
}

/* ===== Profile Header ===== */
.header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 160rpx !important;
  height: 160rpx !important;
  border-radius: 80rpx;
  background-color: #ebebeb;
  position: relative;
  overflow: visible;
  border: none;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  display: block;
}

.edit-badge {
  position: absolute;
  bottom: 0;
  right: -10rpx;
  background-color: #171717;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #fff;
}

/* ===== Identity Badge ===== */
.identity-badge {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #171717 0%, #333 100%);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.id-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.id-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 1rpx;
}

/* ===== Form ===== */
.form-group {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 30rpx;
  color: #333333;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #171717;
}

.phone-display {
  color: #10b981;
  font-weight: 500;
}

/* ===== Actions ===== */
.action-area {
  margin-top: 80rpx;
}

.save-btn {
  background-color: #171717;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 20rpx 0;
}

.save-btn:active {
  opacity: 0.8;
}

.logout-btn {
  margin-top: 24rpx;
  background-color: transparent;
  color: #999;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  color: #e53e3e;
}

/* ===== Floor Plans ===== */
.floorplan-group {
  margin-top: 60rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.group-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #171717;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.floorplan-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx dashed #ebebeb;
}

.floorplan-item:last-child {
  border-bottom: none;
}

.fp-info {
  display: flex;
  flex-direction: column;
}

.fp-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.fp-date {
  font-size: 22rpx;
  color: #999;
}

.fp-status {
  font-size: 24rpx;
  color: #10b981;
  background: #d1fae5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
