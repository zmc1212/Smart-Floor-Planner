<view class="container">

  <!-- ======== 未登录状态 ======== -->
  <view wx:if="{{!isLoggedIn}}" class="login-section">
    <view class="login-icon">
      <image class="login-logo" src="{{defaultAvatarUrl}}"></image>
    </view>
    <view class="login-title">智能量房大师</view>
    <view class="login-subtitle">请使用手机号快捷登录以使用完整功能</view>
    <button class="login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      手机号快捷登录
    </button>
  </view>

  <!-- ======== 已登录状态 ======== -->
  <view wx:else>
    <view class="header">
      <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar" src="{{userInfo.avatar || defaultAvatarUrl}}"></image>
        <view class="edit-badge">修改</view>
      </button>
    </view>

    <view class="form-group">
      <view class="form-item">
        <view class="label">昵称</view>
        <input type="nickname" class="input" placeholder="请输入昵称" value="{{userInfo.nickname}}" bindblur="onNicknameChange"/>
      </view>
      <view class="form-item">
        <view class="label">手机号</view>
        <view class="input phone-display">{{userInfo.phone}}</view>
      </view>
      <view class="form-item">
        <view class="label">小区名称</view>
        <input type="text" class="input" placeholder="请输入小区名称" value="{{userInfo.communityName}}" bindinput="onCommunityNameChange"/>
      </view>
    </view>

    <view class="action-area">
      <button class="save-btn" bindtap="onSaveProfile">保存信息</button>
      <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>

    <view class="floorplan-group" wx:if="{{floorPlans.length > 0}}">
      <view class="group-title">我的户型图 ({{floorPlans.length}})</view>
      <view class="floorplan-list">
        <view class="floorplan-item" wx:for="{{floorPlans}}" wx:key="_id" data-id="{{item._id}}" bindtap="onOpenFloorPlan">
          <view class="fp-info">
            <text class="fp-name">{{item.name}}</text>
            <text class="fp-date">{{item.createdAt}}</text>
          </view>
          <view class="fp-actions">
            <text class="fp-status">{{item.status === 'completed' ? '已完成' : '草稿'}}</text>
            <view class="ai-btn" catchtap="onAIGen" data-id="{{item._id}}">✨ 效果图</view>
          </view>
        </view>
      </view>
    </view>
  </view>

</view>
