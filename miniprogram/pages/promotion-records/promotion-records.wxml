<view class="page">
  <view class="header">
    <view>
      <view class="title">{{title}}</view>
      <view class="subtitle">共 {{records.length}} 条</view>
    </view>
    <button wx:if="{{view === 'my'}}" class="create-btn" bindtap="onCreateRecord">新建报备</button>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>

  <view wx:elif="{{records.length > 0}}">
    <view class="card" wx:for="{{records}}" wx:key="key" data-id="{{useTodoApi ? item.recordId : item._id}}" bindtap="onOpenDetail">
      <view class="row">
        <view class="name">{{useTodoApi ? item.title : item.enterpriseName}}</view>
        <view class="badge {{useTodoApi && item.overdue ? 'badge-warn' : ''}}">
          {{useTodoApi ? (item.overdue ? '已超时' : '待处理') : item.businessStage}}
        </view>
      </view>
      <view class="meta">{{useTodoApi ? item.enterpriseName : item.contactPerson}} · {{useTodoApi ? item.contactPerson : item.phone}}</view>
      <view class="meta" wx:if="{{!useTodoApi}}">归属：{{item.promoterId.displayName || item.promoterId.username || '-'}}</view>
      <view class="meta" wx:if="{{!useTodoApi}}">测量：{{item.measureTask.status}} / 设计：{{item.designTask.status}}</view>
      <view class="meta" wx:if="{{useTodoApi}}">{{item.summary}}</view>
      <view class="meta" wx:if="{{useTodoApi && item.dueLabel}}">截止：{{item.dueLabel}}</view>
    </view>
  </view>

  <view wx:else class="empty">暂无数据</view>
</view>
