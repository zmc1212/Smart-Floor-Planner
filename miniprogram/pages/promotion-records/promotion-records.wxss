.page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 32rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.create-btn {
  margin: 0;
  background: #111827;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.create-btn::after {
  border: none;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 0 0 1rpx rgba(15, 23, 42, 0.05);
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.badge {
  font-size: 20rpx;
  color: #2563eb;
  background: #eff6ff;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.badge-warn {
  color: #c2410c;
  background: #fff7ed;
}

.meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.empty {
  text-align: center;
  color: #94a3b8;
  padding: 120rpx 0;
  font-size: 28rpx;
}
