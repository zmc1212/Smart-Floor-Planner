.container {
  min-height: 100vh;
  background-color: #fafafa;
  padding: 32rpx;
}

.header {
  background: #ffffff;
  padding: 48rpx 40rpx;
  border-radius: 24rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.08), 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #171717;
  margin-bottom: 24rpx;
  letter-spacing: -1rpx;
}

.info {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state .title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.empty-state .subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.template-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 32rpx;
}

.template-item {
  width: calc(50% - 12rpx);
  background: #ffffff;
  padding: 40rpx 0;
  text-align: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
  transition: all 0.2s;
}

.template-item:active {
  background: #f5f5f5;
  transform: scale(0.97);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.add-btn {
  font-size: 24rpx;
  color: #171717;
  font-weight: 600;
  background: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.room-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.room-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.08), 0 2rpx 4rpx rgba(0,0,0,0.02);
  transition: all 0.2s;
}

.room-item:active {
  background: #fafafa;
  transform: scale(0.98);
}

.room-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.room-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.room-status {
  font-size: 22rpx;
  color: #f59e0b;
  background: #fffbeb;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 600;
  box-shadow: 0 0 0 1px rgba(245,158,11,0.1);
}

.room-status.measured {
  color: #16a34a;
  background: #f0fdf4;
  box-shadow: 0 0 0 1px rgba(22,163,74,0.1);
}