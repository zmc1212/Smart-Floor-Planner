.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fafc;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  white-space: nowrap;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin: 0 16rpx;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 999rpx;
  background: #f1f5f9;
  transition: all 0.2s;
}

.filter-item.active {
  background: #1296db;
  color: #fff;
  font-weight: bold;
}

/* 案例列表 */
.case-list {
  flex: 1;
  height: 0;
}

.case-grid {
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.case-card {
  width: 340rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.case-cover-box {
  position: relative;
  width: 100%;
  height: 340rpx;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(0,0,0,0.2);
}

.case-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-weight: bold;
}

.case-info {
  padding: 20rpx;
}

.case-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.case-meta {
  margin-top: 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.case-tag {
  font-size: 20rpx;
  color: #1296db;
  background: #e6f7ff;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.case-views {
  font-size: 20rpx;
  color: #94a3b8;
}

.case-actions {
  margin-top: 20rpx;
}

.btn-copy {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  color: #475569;
  font-size: 22rpx;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.btn-copy:active {
  background: #eff6ff;
  border-color: #1296db;
  color: #1296db;
}

/* 状态展示 */
.loading-status {
  padding: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

/* 悬浮按钮 */
.float-lead-btn {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
  color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 32rpx rgba(15,23,42,0.3);
}

.float-lead-btn:active {
  transform: scale(0.98);
}
