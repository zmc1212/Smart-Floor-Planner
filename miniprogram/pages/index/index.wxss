.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ffffff;
  overflow: hidden;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.branding-banner {
  margin: 24rpx 32rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.brand-logo {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 0 0 1rpx rgba(0,0,0,0.05);
}

.brand-info {
  display: flex;
  flex-direction: column;
}

.brand-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #171717;
  letter-spacing: -0.5rpx;
}

.brand-tagline {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}

/* 浮动：获取报价 */
.floating-btn-lead {
  position: absolute;
  right: 32rpx;
  bottom: 240rpx;
  z-index: 100;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #1296db 0%, #0072f5 100%);
  padding: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(18, 150, 219, 0.3);
  animation: float-pulse 2s infinite ease-in-out;
}

.floating-btn-lead-inner {
  background: #ffffff;
  color: #1296db;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
}

@keyframes float-pulse {
  0% { transform: translateY(0); box-shadow: 0 8rpx 24rpx rgba(18, 150, 219, 0.3); }
  50% { transform: translateY(-10rpx); box-shadow: 0 16rpx 32rpx rgba(18, 150, 219, 0.4); }
  100% { transform: translateY(0); box-shadow: 0 8rpx 24rpx rgba(18, 150, 219, 0.3); }
}
