.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f9fa;
  overflow: hidden;
}

/* 自定义导航栏 */
.nav-bar {
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  z-index: 20;
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  height: 88rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.logo-box {
  width: 64rpx;
  height: 64rpx;
  background: #2563eb;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.2;
}

.app-subtitle {
  font-size: 16rpx;
  color: #9ca3af;
  letter-spacing: 3rpx;
  font-weight: 500;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-group {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 4rpx;
  gap: 4rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #4b5563;
}

.action-btn:active {
  background: rgba(255,255,255,0.8);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.action-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.nav-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e5e7eb;
  margin: 0 8rpx;
}

/* 主内容区 */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.canvas-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

/* 微信小程序自定义组件默认是 inline，必须设置 block 才能有尺寸 */
floor-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

toolbar {
  display: block;
  width: 100%;
}

properties {
  display: block;
  width: 100%;
}

/* 绘制模式指示器 */
.drawing-indicator {
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(17,24,39,0.9);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  z-index: 50;
  white-space: nowrap;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #3b82f6;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.indicator-text {
  color: #ffffff;
}

.indicator-cancel {
  color: #9ca3af;
  font-size: 22rpx;
  text-decoration: underline;
  margin-left: 8rpx;
}

/* 底部状态栏 */
.status-bar {
  height: 88rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.status-text {
  font-size: 24rpx;
  color: #6b7280;
  font-family: monospace;
}

.ble-btn {
  font-size: 26rpx;
  background: #2563eb;
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
}

.ble-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.status-ready {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 700;
  font-family: monospace;
}
