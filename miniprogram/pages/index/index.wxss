.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f9fa;
  overflow: hidden;
}

/* 主内容区 */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.canvas-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

/* 微信小程序自定义组件默认是 inline，必须设置 block 才能有尺寸 */
floor-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

toolbar {
  display: block;
  width: 100%;
}

properties {
  display: block;
  width: 100%;
}

/* 绘制模式指示器 */
.drawing-indicator {
  position: absolute;
  top: 70rpx;
  right: 24rpx;
  background: rgba(17,24,39,0.9);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  z-index: 50;
  white-space: nowrap;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #3b82f6;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.indicator-text {
  color: #ffffff;
}

.indicator-cancel {
  color: #9ca3af;
  font-size: 22rpx;
  text-decoration: underline;
  margin-left: 8rpx;
}

/* 快速聚焦按钮 */
.focus-btn {
  position: absolute;
  right: 32rpx;
  bottom: 120rpx;
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  border: 1rpx solid rgba(0,0,0,0.05);
  z-index: 40;
}

.focus-btn:active {
  transform: scale(0.9);
  background: #f3f4f6;
}

.focus-icon {
  font-size: 40rpx;
  color: #3b82f6;
  font-weight: bold;
}
