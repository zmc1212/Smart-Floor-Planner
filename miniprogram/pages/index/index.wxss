.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ffffff;
  overflow: hidden;
}

/* 主内容区 */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.canvas-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

floor-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

toolbar {
  display: block;
  width: 100%;
}

properties {
  display: block;
  width: 100%;
}

/* 绘制模式指示器 - Vercel Dark Style */
.drawing-indicator {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #171717;
  color: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 10px 30rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 100;
  white-space: nowrap;
}

.indicator-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--develop-blue);
  box-shadow: 0 0 10rpx var(--develop-blue);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.indicator-text {
  color: #ffffff;
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
}

.indicator-cancel {
  color: var(--ds-gray-400);
  font-size: 20rpx;
  text-decoration: none;
  border-left: 1rpx solid rgba(255,255,255,0.2);
  padding-left: 16rpx;
  margin-left: 8rpx;
}

/* 快速聚焦按钮 */
.focus-btn {
  position: absolute;
  right: 48rpx;
  bottom: 120rpx;
  width: 88rpx;
  height: 88rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0px 0px 0px 1px rgba(0,0,0,0.08), 
    0px 4rpx 12rpx rgba(0,0,0,0.08);
  z-index: 40;
  transition: all 0.2s;
}

.focus-btn:active {
  transform: scale(0.9) translateY(2rpx);
  background: #fafafa;
}

.focus-icon {
  font-size: 40rpx;
  color: #171717;
  font-weight: bold;
}


.three-canvas-container {
  width: 100%;
  height: 100%;
  position: relative;
}
.three-canvas {
  width: 100%;
  height: 100%;
}

.three-controls {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 16rpx;
  z-index: 999;
  background: rgba(255,255,255,0.95);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.three-btn {
  font-size: 24rpx;
  color: #333;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  font-weight: 500;
  white-space: nowrap;
}
.three-btn:active {
  background: #e0e0e0;
}

