.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f9fa;
  overflow: hidden;
}

/* 自定义导航栏 */
.nav-bar {
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  z-index: 20;
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.logo-box {
  width: 52rpx;
  height: 52rpx;
  background: #2563eb;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 28rpx;
  color: #ffffff;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.1;
}

.app-subtitle {
  font-size: 14rpx;
  color: #9ca3af;
  letter-spacing: 2rpx;
  font-weight: 500;
  margin-top: -2rpx;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-group {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 4rpx;
  gap: 4rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #4b5563;
}

.action-btn:active {
  background: rgba(255,255,255,0.8);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.action-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.nav-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e5e7eb;
  margin: 0 8rpx;
}

/* 主内容区 */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.canvas-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

/* 微信小程序自定义组件默认是 inline，必须设置 block 才能有尺寸 */
floor-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

toolbar {
  display: block;
  width: 100%;
}

properties {
  display: block;
  width: 100%;
}

/* 绘制模式指示器 */
.drawing-indicator {
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(17,24,39,0.9);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  z-index: 50;
  white-space: nowrap;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #3b82f6;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.indicator-text {
  color: #ffffff;
}

.indicator-cancel {
  color: #9ca3af;
  font-size: 22rpx;
  text-decoration: underline;
  margin-left: 8rpx;
}

/* 底部状态栏 */
.status-bar {
  height: 88rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.status-text {
  font-size: 24rpx;
  color: #6b7280;
  font-family: monospace;
}

.ble-btn {
  font-size: 26rpx;
  background: #2563eb;
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
}

.ble-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.status-ready {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 700;
  font-family: monospace;
}

/* 户型库视图 */
.library-container {
  flex: 1;
  padding: 32rpx;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.library-header {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #111827;
}

.layout-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.layout-btn {
  padding: 16rpx 32rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
}

.layout-btn.active {
  background: #eff6ff;
  border-color: #3b82f6;
  color: #1d4ed8;
}

.room-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.room-item {
  width: calc(50% - 12rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid transparent;
}

.room-item-measured {
  background: #f0fdf4;
  border-color: #34d399;
}

.room-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.room-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.room-status {
  font-size: 24rpx;
  color: #9ca3af;
}

.room-status.measured {
  color: #059669;
}

/* 引导式模式横幅 */
.guided-wizard-bar {
  width: 100%;
  background: #3b82f6;
  color: white;
  padding: 32rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  z-index: 100;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.wizard-text {
  flex: 1;
  text-align: center;
}

.wizard-btn-action {
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin: 0 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.wizard-cancel {
  padding: 0 24rpx;
  font-size: 24rpx;
  text-decoration: underline;
}

/* 蓝牙强制连接引导页 */
.ble-entry-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  padding: 40rpx;
}

.ble-entry-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.ble-entry-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.ble-entry-subtitle {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 60rpx;
  text-align: center;
}

.ble-action-group {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  width: 100%;
  max-width: 500rpx;
}

.ble-btn-primary {
  background: #2563eb;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 100rpx;
  text-align: center;
  box-shadow: 0 8rpx 16rpx rgba(37, 99, 235, 0.2);
}

.ble-btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.ble-btn-outline {
  border: 2rpx solid #e5e7eb;
  background: #ffffff;
  color: #4b5563;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 100rpx;
  text-align: center;
}

.ble-btn-outline:active {
  background: #f3f4f6;
}

/* 测量弹窗 */
.measure-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.measure-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.2);
  display: flex;
  flex-direction: column;
}

.measure-modal-header {
  background: #2563eb;
  color: #fff;
  padding: 30rpx;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
}

.measure-modal-content {
  padding: 60rpx 40rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #374151;
  text-align: center;
}

.measure-modal-footer {
  padding: 0 40rpx 40rpx;
}

.measure-btn-confirm {
  background: #10b981;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  padding: 24rpx;
  border-radius: 100rpx;
  text-align: center;
  box-shadow: 0 8rpx 16rpx rgba(16, 185, 129, 0.2);
}

.measure-btn-confirm:active {
  opacity: 0.8;
  transform: scale(0.98);
}
