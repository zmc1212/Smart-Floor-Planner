<view class="page-container">
  <!-- 1. 自定义导航栏 -->
  <nav-bar 
    navBarHeightTotal="{{navBarHeightTotal}}"
    statusBarHeight="{{statusBarHeight}}"
    capsulePadding="{{capsulePadding}}"
    canUndo="{{false}}"
    canRedo="{{false}}"
    showHistory="{{false}}"
  />

  <view class="main-content">
    <!-- 企业品牌展示 (Whitelabel) -->
    <view class="branding-banner" wx:if="{{branding}}" style="border-left: 8rpx solid {{branding.branding.primaryColor}}">
      <image class="brand-logo" src="{{branding.logo || '/assets/icons/logo.png'}}" mode="aspectFit" />
      <view class="brand-info">
        <text class="brand-name">{{branding.name}}</text>
        <text class="brand-tagline">专业量房·智能快装</text>
      </view>
    </view>

    <!-- 2. 蓝牙强制连接引导页 -->
    <ble-gate 
      wx:if="{{!bleConnected}}" 
      bindautoconnect="onAutoConnectBLE"
      bindconnect="onConnectBLE"
    />

    <block wx:else>
      <!-- 3. 户型库视图 -->
      <room-library 
        plannedRooms="{{plannedRooms}}"
        layoutTemplates="{{layoutTemplates}}"
        myCloudFloorPlans="{{myCloudFloorPlans}}"
        bindselectlayout="onSelectLayout"
        bindopencloudplan="onOpenCloudPlan"
        bindresetlayout="onResetLayout"
        bindenterroom="onEnterRoom"
        bindaddroom="onAddRoom"
        bindaigen="onAIGen"
      />
    </block>
  </view>

  <!-- 浮动：获取报价/设计 -->
  <view class="floating-btn-lead" bindtap="onOpenLeadModal">
    <view class="floating-btn-lead-inner">{{userInfo.role === 'staff' ? '开始量房绑定客户' : '免费设计与报价'}}</view>
  </view>

  <lead-modal show="{{showLeadModal}}" bindclose="onCloseLeadModal" bindsuccess="onLeadSuccess" />
</view>
