<view class="atelier-container">
  <!-- 1. 顶部导航与模式切换 -->
  <view class="atelier-header">
    <view class="nav-back" bindtap="onBack">
      <icon type="back" size="20" color="#333" />
    </view>
    <view class="segmented-control">
      <view 
        class="segment-item {{selectedMode === 'INTERIOR' ? 'active' : ''}}" 
        data-mode="INTERIOR" 
        bindtap="onModeChange"
      >效果图</view>
      <view 
        class="segment-item {{selectedMode === 'PLANE' ? 'active' : ''}}" 
        data-mode="PLANE" 
        bindtap="onModeChange"
      >平面图</view>
    </view>
    <view class="nav-spacer"></view>
  </view>

  <scroll-view scroll-y class="atelier-content" enhanced show-scrollbar="{{false}}">
    <!-- 2. Hero 预览区 -->
    <view class="hero-preview-section">
      <view class="preview-frame {{isGenerating ? 'is-generating' : ''}}">
        <block wx:if="{{room.renderingUrl}}">
          <image 
            src="{{room.renderingUrl}}" 
            mode="aspectFill" 
            class="main-rendering" 
            bindtap="onPreviewImage"
          />
          <view class="glass-tag top-right">AI 原创设计</view>
          <view class="glass-tag bottom-left dimensions">
            <text class="dim-text">{{room.width/10}}m × {{room.height/10}}m</text>
          </view>
        </block>
        <block wx:else>
          <view class="empty-state">
            <view class="empty-glow"></view>
            <text class="empty-icon">🎨</text>
            <text class="empty-title">Studio Preview</text>
            <text class="empty-desc">配置下方风格，开启智绘空间</text>
          </view>
        </block>
        
        <!-- 生成中的扫描线动画 -->
        <view class="scan-line" wx:if="{{isGenerating}}"></view>
      <!-- Result Actions -->
      <view class="result-actions" wx:if="{{room.renderingUrl && !isGenerating}}">
        <button class="action-btn" bindtap="onPreviewImage">预览大图</button>
        <button class="action-btn primary" bindtap="onOpenLeadModal">获取完整设计方案</button>
        <button class="action-btn secondary" bindtap="onExportPrompt">复制设计提示词</button>
      </view>
    </view>
  </view>

  <!-- Lead Modal -->
  <lead-modal 
    show="{{showLeadModal}}" 
    roomName="{{room.name}}"
    bind:close="onCloseLeadModal"
    bind:success="onLeadSuccess"
  />

    <!-- 3. 房间基本信息 -->
    <view class="room-memo">
      <view class="memo-line"></view>
      <text class="memo-name">{{room.name}}</text>
      <text class="memo-status">已连接测绘数据</text>
    </view>

    <!-- 4. 风格研选 (Horizontal Grid) -->
    <view class="atelier-section">
      <view class="section-head">
        <text class="head-title">风格研选</text>
        <text class="head-subtitle">Style Selection</text>
      </view>
      
      <scroll-view scroll-x class="style-palette" enable-flex enhanced show-scrollbar="{{false}}">
        <view 
          wx:for="{{styleMetadata}}" 
          wx:key="key" 
          class="palette-item {{selectedStyleKey === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onStyleSelect"
        >
          <view class="palette-preview" style="background: linear-gradient(135deg, {{item.color}}, {{item.textColor}}22);">
            <view class="style-initial" style="color: {{item.textColor}}">{{item.label[0]}}</view>
            <view class="active-check" wx:if="{{selectedStyleKey === item.key}}">
              <icon type="success_no_circle" size="12" color="#fff" />
            </view>
          </view>
          <text class="palette-label">{{item.label}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 5. AI 设计建议 -->
    <view class="atelier-section">
      <view class="section-head">
        <text class="head-title">设计策展</text>
        <text class="head-subtitle">Design Curation</text>
      </view>

      <view class="advice-atelier-card {{room.designAdvice ? 'has-content' : ''}}">
        <block wx:if="{{room.designAdvice}}">
          <view class="advice-quotes">“</view>
          <text class="advice-body">{{room.designAdvice.content}}</text>
          <view class="advice-footer">
            <text class="consultant-tag">AI Senior Designer</text>
          </view>
        </block>
        <block wx:else>
          <view class="advice-empty-body" bindtap="onGetAdvice">
            <text>点击获取该空间的专业软硬装搭配方案</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 6. 底部引流 Banner -->
    <view class="atelier-section">
      <view class="lead-atelier-banner" bindtap="onOpenLeadModal">
        <view class="lead-main">
          <text class="lead-h1">获取完整设计方案</text>
          <text class="lead-p">专业设计师 1对1 免费服务</text>
        </view>
        <view class="lead-arrow">→</view>
      </view>
    </view>

    <view class="footer-gap"></view>
  </scroll-view>

  <!-- 7. 固定底部操作区 -->
  <view class="fixed-bottom-bar">
    <view class="btn-group">
      <view class="btn-secondary {{isGettingAdvice ? 'is-loading' : ''}}" bindtap="onGetAdvice">
        <text>{{isGettingAdvice ? '咨询中...' : '咨询设计建议'}}</text>
      </view>
      <view class="btn-primary {{isGenerating ? 'is-loading' : ''}}" bindtap="onGenerate">
        <text>{{isGenerating ? 'AI 智绘中...' : '生成渲染方案'}}</text>
      </view>
    </view>
  </view>

  <lead-modal show="{{showLeadModal}}" bindclose="onCloseLeadModal" bindsuccess="onLeadSuccess" />
</view>
