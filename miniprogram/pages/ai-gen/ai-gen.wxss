/* pages/ai-gen/ai-gen.wxss */

/* --- 核心容器与调色盘 --- */
.atelier-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #fcfcfd;
  color: #1a1c1e;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* --- 精致顶部栏 --- */
.atelier-header {
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(252, 252, 253, 0.8);
  backdrop-filter: blur(20px);
  z-index: 100;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.segmented-control {
  flex: 1;
  max-width: 360rpx;
  height: 72rpx;
  background: #f1f3f5;
  border-radius: 36rpx;
  display: flex;
  padding: 4rpx;
  position: relative;
}

.segment-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #868e96;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 2;
}

.segment-item.active {
  color: #1a1c1e;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.nav-spacer {
  width: 80rpx;
}

/* --- 内容区域 --- */
.atelier-content {
  flex: 1;
  height: 0;
}

/* --- Hero 预览区 --- */
.hero-preview-section {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-frame {
  width: 100%;
  height: 480rpx;
  background: #f1f3f5;
  border-radius: 40rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 40rpx 80rpx -20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.5s ease;
}

.preview-frame.is-generating {
  transform: scale(0.98);
  box-shadow: 0 10rpx 30rpx rgba(79, 70, 229, 0.1);
}

.main-rendering {
  width: 100%;
  height: 100%;
}

.glass-tag {
  position: absolute;
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 99rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #1a1c1e;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.top-right { top: 24rpx; right: 24rpx; }
.bottom-left { bottom: 24rpx; left: 24rpx; }

.dim-text {
  font-family: 'SF Mono', 'Roboto Mono', monospace;
  letter-spacing: 0.5px;
}

/* --- 空状态设计 --- */
.empty-state {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
}

.empty-glow {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(79, 70, 229, 0.15) 0%, transparent 70%);
  z-index: 1;
}

.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; z-index: 2; }
.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #495057;
  margin-bottom: 12rpx;
  z-index: 2;
}
.empty-desc { font-size: 24rpx; color: #adb5bd; z-index: 2; }

/* --- 扫描线动画 --- */
.scan-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(to bottom, transparent, #4f46e5, transparent);
  box-shadow: 0 0 20rpx #4f46e5;
  animation: scan 1.5s ease-in-out infinite;
  z-index: 10;
}

@keyframes scan {
  0% { top: 0%; opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { top: 100%; opacity: 0; }
}

/* --- 快捷按钮 --- */
.preview-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.action-pill {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #495057;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f1f3f5;
}

.action-pill.primary {
  background: #f1f3f5;
  border-color: transparent;
}

/* --- 房间概览 --- */
.room-memo {
  display: flex;
  align-items: center;
  padding: 0 48rpx 40rpx;
}

.memo-line {
  width: 4rpx;
  height: 24rpx;
  background: #4f46e5;
  margin-right: 16rpx;
  border-radius: 2rpx;
}

.memo-name {
  font-size: 36rpx;
  font-weight: 800;
  margin-right: 16rpx;
}

.memo-status {
  font-size: 22rpx;
  color: #adb5bd;
  font-weight: 500;
}

/* --- 章节样式 --- */
.atelier-section {
  padding: 0 40rpx 60rpx;
}

.section-head {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.head-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1c1e;
  letter-spacing: 1px;
}

.head-subtitle {
  font-size: 18rpx;
  color: #adb5bd;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-top: 4rpx;
}

/* --- 风格调色盘 --- */
.style-palette {
  display: flex;
  white-space: nowrap;
  width: 100vw;
  margin-left: -40rpx;
  padding: 30rpx 40rpx;
  box-sizing: border-box;
}

.palette-item {
  flex-shrink: 0;
  margin-right: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 130rpx;
  padding: 10rpx 0;
}

.palette-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 10rpx 20rpx -5rpx rgba(0, 0, 0, 0.05);
}

.palette-item:last-child {
  margin-right: 40rpx;
}

.palette-item.active .palette-preview {
  transform: scale(1.1);
  box-shadow: 0 20rpx 40rpx -10rpx rgba(79, 70, 229, 0.3);
}

.style-initial {
  font-size: 40rpx;
  font-weight: 800;
  opacity: 0.6;
}

.active-check {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #4f46e5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
}

.palette-label {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #495057;
  font-weight: 500;
}

.palette-item.active .palette-label {
  color: #4f46e5;
  font-weight: 700;
}

/* --- 设计策展卡片 --- */
.advice-atelier-card {
  background: #ffffff;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  position: relative;
  border: 1rpx solid #f1f3f5;
}

.advice-atelier-card.has-content {
  background: linear-gradient(135deg, #ffffff 0%, #f1f3f5 100%);
}

.advice-quotes {
  font-size: 80rpx;
  color: #e9ecef;
  margin-bottom: -40rpx;
  margin-top: -30rpx;
  font-family: Georgia, serif;
}

.advice-body {
  font-size: 26rpx;
  line-height: 1.8;
  color: #495057;
  display: block;
}

.advice-footer {
  margin-top: 32rpx;
  display: flex;
  justify-content: flex-end;
}

.consultant-tag {
  font-size: 18rpx;
  color: #4f46e5;
  background: rgba(79, 70, 229, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.advice-empty-body {
  padding: 20rpx 0;
  color: #adb5bd;
  font-size: 24rpx;
  text-align: center;
}

/* --- 引流横幅 --- */
.lead-atelier-banner {
  background: #1a1c1e;
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.1);
}

.lead-main { display: flex; flex-direction: column; }
.lead-h1 { color: #fff; font-size: 30rpx; font-weight: 700; }
.lead-p { color: #adb5bd; font-size: 22rpx; margin-top: 8rpx; }
.lead-arrow { color: #fff; font-size: 40rpx; opacity: 0.8; }

.footer-gap { height: 240rpx; }

/* --- 吸底操作区 --- */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  z-index: 1000;
  border-top: 1rpx solid #f1f3f5;
}

.btn-group {
  display: flex;
  gap: 24rpx;
}

.btn-primary, .btn-secondary {
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  transition: all 0.3s;
}

.btn-primary {
  flex: 3;
  background: #1a1c1e;
  color: #fff;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.15);
}

.btn-secondary {
  flex: 2;
  background: #f1f3f5;
  color: #495057;
}

.btn-primary:active, .btn-secondary:active {
  transform: translateY(4rpx);
  opacity: 0.9;
}

.is-loading { opacity: 0.6; pointer-events: none; }
