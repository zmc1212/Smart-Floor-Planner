.page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 0 0 1rpx rgba(15, 23, 42, 0.05);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.input,
.textarea,
.picker {
  width: 100%;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.textarea {
  min-height: 160rpx;
}

.primary-btn,
.secondary-btn {
  margin-top: 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.primary-btn {
  background: #111827;
  color: #ffffff;
}

.secondary-btn {
  background: #ffffff;
  color: #111827;
  box-shadow: 0 0 0 1rpx rgba(15, 23, 42, 0.08);
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.log {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e2e8f0;
}

.log-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
}

.log-content {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.empty {
  text-align: center;
  color: #94a3b8;
  padding: 120rpx 0;
  font-size: 28rpx;
}
