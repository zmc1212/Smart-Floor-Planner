.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ffffff;
  overflow: hidden;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.canvas-area {
  flex: 1;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

floor-canvas {
  flex: 1;
  display: block;
  width: 100%;
}

toolbar {
  display: block;
  width: 100%;
}

properties {
  display: block;
  width: 100%;
}

/* 绘制模式指示器 */
.drawing-indicator {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #171717;
  color: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 10px 30rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 100;
  white-space: nowrap;
}

.indicator-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--develop-blue);
  box-shadow: 0 0 10rpx var(--develop-blue);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.indicator-text {
  color: #ffffff;
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
}

.indicator-cancel {
  color: var(--ds-gray-400);
  font-size: 20rpx;
  text-decoration: none;
  border-left: 1rpx solid rgba(255,255,255,0.2);
  padding-left: 16rpx;
  margin-left: 8rpx;
}

/* 3D */
.three-canvas-container {
  flex: 1;
  width: 100%;
  position: relative;
}
.three-canvas {
  width: 100%;
  height: 100%;
}

.three-controls {
  position: absolute;
  bottom: 60rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  z-index: 999;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20px);
  padding: 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
}

.three-btn {
  font-size: 24rpx;
  color: #333;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  font-weight: 500;
  white-space: nowrap;
}
.three-btn:active {
  background: #e0e0e0;
}
